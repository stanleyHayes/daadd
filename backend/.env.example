NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/adplatform

# Auth — JWT_SECRET is REQUIRED in production (boot fails without it, spec §9).
# Access tokens default to 1h; clients renew via POST /auth/refresh.
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# QR redemption signing (falls back to JWT_SECRET when unset)
QR_SIGNING_SECRET=

# Redemption economics
TOKEN_VALUE=0.05
MAX_DISCOUNT_PCT=0.15
QR_EXPIRY_SECONDS=120

# CORS: comma-separated allow-list. Production blocks cross-origin requests when unset.
CORS_ORIGINS=http://localhost:3000

# URLs (password-reset links, future OAuth redirect URIs)
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Email: Resend (dev exposes inline dev tokens when unset)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

# AI creative generation
ANTHROPIC_API_KEY=

# Platform OAuth (spec §8.3) — required once platform adapters are implemented
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
META_OAUTH_APP_ID=
META_OAUTH_APP_SECRET=
TIKTOK_OAUTH_CLIENT_ID=
TIKTOK_OAUTH_CLIENT_SECRET=
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=
PINTEREST_OAUTH_CLIENT_ID=
PINTEREST_OAUTH_CLIENT_SECRET=
# AES-256-GCM key for encrypting platform tokens at rest (future)
ENCRYPTION_SECRET=

# Payments (optional — only if Stripe is enabled)
STRIPE_SECRET_KEY=

# Storage: local uploads/ by default; S3 activates when these are set AND
# @aws-sdk/client-s3 is installed (see src/services/storage.service.ts)
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Redis — reserved for future queues/cache; the live server does not require it
REDIS_HOST=localhost
REDIS_PORT=6379

# Seeding — never seed in production unless explicitly enabled
# SEED_DATABASE=false
