{
  "name": "@daadd/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsup src/server.ts --format cjs --out-dir dist --target node20 --sourcemap --clean --external @aws-sdk/client-s3",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "test": "jest --passWithNoTests",
    "seed": "ts-node --transpile-only src/database/seeds/seed.ts",
    "seed:team": "ts-node --transpile-only src/seed-team.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.16",
