{
  "name": "daadd",
  "version": "1.0.0",
  "private": true,
  "description": "DAADD - Two-sided AdTech and Analytics Platform",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npx concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:all": "npx concurrently -n backend,frontend,mobile -c blue,green,yellow \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:mobile\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:mobile": "cd mobile && npx expo start --port 8082 --non-interactive",
    "start": "npx concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:shared": "npm run build --workspace=shared",
    "build:all": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "test:backend": "npm run test --workspace=backend",
    "test:frontend": "npm run test --workspace=frontend",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "npm run migration:run --workspace=backend",
    "db:seed": "npm run seed --workspace=backend"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.1",
    "commitlint": "^21.0.1",
    "concurrently": "^9.2.1",
    "html-pdf": "^3.0.1",
    "html2pdf.js": "^0.14.0",
    "husky": "^9.1.7",
    "markdown-pdf": "^11.0.0",
    "marked": "^18.0.3",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.9.5"
  }
}
